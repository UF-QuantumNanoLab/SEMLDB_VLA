      idvd_poly_feat[79] = pow(input_x[1], 4) * pow(input_x[2], 2);
      idvd_poly_feat[80] = pow(input_x[1], 3) * pow(input_x[2], 3);
      idvd_poly_feat[81] = pow(input_x[1], 2) * pow(input_x[2], 4);
      idvd_poly_feat[82] = pow(input_x[1], 1) * pow(input_x[2], 5);
      idvd_poly_feat[83] = pow(input_x[2], 6);
      idvd_poly_feat[84] = pow(input_x[0], 7);
      idvd_poly_feat[85] = pow(input_x[0], 6) * pow(input_x[1], 1);
      idvd_poly_feat[86] = pow(input_x[0], 6) * pow(input_x[2], 1);
      idvd_poly_feat[87] = pow(input_x[0], 5) * pow(input_x[1], 2);
      idvd_poly_feat[88] = pow(input_x[0], 5) * pow(input_x[1], 1) * pow(input_x[2], 1);
