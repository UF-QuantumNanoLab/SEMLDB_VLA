      idvd_poly_feat[24] = pow(input_x[0], 2) * pow(input_x[1], 1) * pow(input_x[2], 1);
      idvd_poly_feat[25] = pow(input_x[0], 2) * pow(input_x[2], 2);
      idvd_poly_feat[26] = pow(input_x[0], 1) * pow(input_x[1], 3);
      idvd_poly_feat[27] = pow(input_x[0], 1) * pow(input_x[1], 2) * pow(input_x[2], 1);
      idvd_poly_feat[28] = pow(input_x[0], 1) * pow(input_x[1], 1) * pow(input_x[2], 2);
      idvd_poly_feat[29] = pow(input_x[0], 1) * pow(input_x[2], 3);
      idvd_poly_feat[30] = pow(input_x[1], 4);
      idvd_poly_feat[31] = pow(input_x[1], 3) * pow(input_x[2], 1);
      idvd_poly_feat[32] = pow(input_x[1], 2) * pow(input_x[2], 2);
      idvd_poly_feat[33] = pow(input_x[1], 1) * pow(input_x[2], 3);
      idvd_poly_feat[34] = pow(input_x[2], 4);
      idvd_poly_feat[35] = pow(input_x[0], 5);
      idvd_poly_feat[36] = pow(input_x[0], 4) * pow(input_x[1], 1);
      idvd_poly_feat[37] = pow(input_x[0], 4) * pow(input_x[2], 1);
      idvd_poly_feat[38] = pow(input_x[0], 3) * pow(input_x[1], 2);
      idvd_poly_feat[39] = pow(input_x[0], 3) * pow(input_x[1], 1) * pow(input_x[2], 1);
      idvd_poly_feat[40] = pow(input_x[0], 3) * pow(input_x[2], 2);
      idvd_poly_feat[41] = pow(input_x[0], 2) * pow(input_x[1], 3);
      idvd_poly_feat[42] = pow(input_x[0], 2) * pow(input_x[1], 2) * pow(input_x[2], 1);
      idvd_poly_feat[43] = pow(input_x[0], 2) * pow(input_x[1], 1) * pow(input_x[2], 2);
