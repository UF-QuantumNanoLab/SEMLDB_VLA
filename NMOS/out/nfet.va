      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_sx_add.txt", "r");
      for(i=0; i<3; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_sx_add[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_sl_mul.txt", "r");
      for(i=0; i<5; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_sl_mul[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_sl_add.txt", "r");
      for(i=0; i<5; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_sl_add[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_siv_mul.txt", "r");
      for(i=0; i<400; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_siv_mul[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_siv_add.txt", "r");
      for(i=0; i<400; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_siv_add[i]);
      $fclose(fd);

      // Convert nm -> um before applying the learned input scalers.
      input_x[0] = (1.0e-3 * Lg) * idvd_sx_mul[0] + idvd_sx_add[0];
      input_x[1] = (1.0e-3 * THF) * idvd_sx_mul[1] + idvd_sx_add[1];
      input_x[2] = (1.0e-3 * XjSD) * idvd_sx_mul[2] + idvd_sx_add[2];
      idvd_poly_feat[0] = 1.0;
      idvd_poly_feat[1] = pow(input_x[0], 1);
      idvd_poly_feat[2] = pow(input_x[1], 1);
      idvd_poly_feat[3] = pow(input_x[2], 1);
      idvd_poly_feat[4] = pow(input_x[0], 2);
      idvd_poly_feat[5] = pow(input_x[0], 1) * pow(input_x[1], 1);
      idvd_poly_feat[6] = pow(input_x[0], 1) * pow(input_x[2], 1);
      idvd_poly_feat[7] = pow(input_x[1], 2);
      idvd_poly_feat[8] = pow(input_x[1], 1) * pow(input_x[2], 1);
      idvd_poly_feat[9] = pow(input_x[2], 2);
      idvd_poly_feat[10] = pow(input_x[0], 3);
      idvd_poly_feat[11] = pow(input_x[0], 2) * pow(input_x[1], 1);
      idvd_poly_feat[12] = pow(input_x[0], 2) * pow(input_x[2], 1);
      idvd_poly_feat[13] = pow(input_x[0], 1) * pow(input_x[1], 2);
      idvd_poly_feat[14] = pow(input_x[0], 1) * pow(input_x[1], 1) * pow(input_x[2], 1);
      idvd_poly_feat[15] = pow(input_x[0], 1) * pow(input_x[2], 2);
      idvd_poly_feat[16] = pow(input_x[1], 3);
      idvd_poly_feat[17] = pow(input_x[1], 2) * pow(input_x[2], 1);
      idvd_poly_feat[18] = pow(input_x[1], 1) * pow(input_x[2], 2);
      idvd_poly_feat[19] = pow(input_x[2], 3);
      idvd_poly_feat[20] = pow(input_x[0], 4);
      idvd_poly_feat[21] = pow(input_x[0], 3) * pow(input_x[1], 1);
