      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_poly_b.txt", "r");
      for(i=0; i<5; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_poly_b[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_w0.txt", "r");
      for(i=0; i<250; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_w0[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_b0.txt", "r");
      for(i=0; i<50; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_b0[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_w1.txt", "r");
      for(i=0; i<10000; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_w1[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_b1.txt", "r");
      for(i=0; i<200; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_b1[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_w2.txt", "r");
