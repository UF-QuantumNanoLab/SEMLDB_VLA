      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_ae_w0.txt", "r");
      for(i=0; i<150; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_ae_w0[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_ae_b0.txt", "r");
      for(i=0; i<50; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_ae_b0[i]);
