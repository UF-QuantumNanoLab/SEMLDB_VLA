      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_ae_w2.txt", "r");
      for(i=0; i<80000; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_ae_w2[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_ae_b2.txt", "r");
      for(i=0; i<400; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_ae_b2[i]);
      $fclose(fd);
