      idvd_poly_feat[49] = pow(input_x[0], 1) * pow(input_x[2], 4);
      idvd_poly_feat[50] = pow(input_x[1], 5);
      idvd_poly_feat[51] = pow(input_x[1], 4) * pow(input_x[2], 1);
      idvd_poly_feat[52] = pow(input_x[1], 3) * pow(input_x[2], 2);
