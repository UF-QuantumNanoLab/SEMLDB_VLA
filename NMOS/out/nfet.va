// Automatically generated Verilog-A planar NMOS drain-current model
`include "constants.vams"
`include "disciplines.vams"

module nfet(d, g, s);
  inout d, g, s;
  electrical d, g, s;

  // Geometry parameters in nm, matching the SEMLDB planar NMOS UI.
  parameter real Lg = 32.0;
  parameter real THF = 2.0;
  parameter real XjSD = 40.0;
  // 0: blended current, 1: Id-Vd surface only, 2: Id-Vg surface only
  parameter integer current_mode = 2;
  parameter real gmin_ds = 1e-12 from [0:inf);
  parameter real vds_sign_delta = 1e-4 from [0:inf);

  real idvd_poly_w[0:704];
  real idvd_poly_b[0:2];
  real idvd_ae_w0[0:149];
  real idvd_ae_b0[0:49];
  real idvd_ae_w1[0:9999];
  real idvd_ae_b1[0:199];
  real idvd_ae_w2[0:79999];
  real idvd_ae_b2[0:399];
  real idvd_ae_w3[0:319999];
  real idvd_ae_b3[0:799];
  real idvg_poly_w[0:599];
  real idvg_poly_b[0:4];
  real idvg_ae_w0[0:249];
  real idvg_ae_b0[0:49];
  real idvg_ae_w1[0:9999];
  real idvg_ae_b1[0:199];
  real idvg_ae_w2[0:79999];
  real idvg_ae_b2[0:399];
  real idvg_ae_w3[0:159999];
  real idvg_ae_b3[0:399];
  real idvd_sx_mul[0:2];
  real idvd_sx_add[0:2];
  real idvd_sl_mul[0:2];
  real idvd_sl_add[0:2];
  real idvd_siv_mul[0:799];
  real idvd_siv_add[0:799];
  real idvg_sx_mul[0:2];
  real idvg_sx_add[0:2];
  real idvg_sl_mul[0:4];
  real idvg_sl_add[0:4];
  real idvg_siv_mul[0:399];
  real idvg_siv_add[0:399];

  // Temporary buffers
  real input_x[0:2];
  real idvd_poly_feat[0:234];
  real idvd_z[0:2];
  real idvd_h0[0:49];
  real idvd_h1[0:199];
  real idvd_h2[0:399];
  real idvd_out[0:799];
  real idvg_poly_feat[0:119];
  real idvg_z[0:4];
  real idvg_h0[0:49];
  real idvg_h1[0:199];
  real idvg_h2[0:399];
  real idvg_out[0:399];
  integer i, j, fd, count_tmp;
  integer idvd_vg0_idx, idvd_vg1_idx, idvd_vd0_idx, idvd_vd1_idx;
  integer idvg_vg0_idx, idvg_vg1_idx, idvg_vd0_idx, idvg_vd1_idx;
  real tmp, val_vg, val_vd, vd_mag, sign_vd, res_id_mag;
  real idvd_vg_pos, idvd_vg_frac, idvd_vd_pos, idvd_vd_frac;
  real idvg_vg_pos, idvg_vg_frac, idvg_vd_frac;
  real idvd_i00, idvd_i01, idvd_i10, idvd_i11, idvd_interp;
  real idvg_i00, idvg_i01, idvg_i10, idvg_i11, idvg_interp;
  real idvd_vg_dist, idvg_vd_dist, idvd_excess, idvg_excess;
  real w_idvd, w_idvg, w_sum;

  analog begin
    @(initial_step) begin
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_poly_w.txt", "r");
      for(i=0; i<705; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_poly_w[i]);
