      idvg_poly_feat[73] = pow(input_x[0], 1) * pow(input_x[1], 3) * pow(input_x[2], 2);
      idvg_poly_feat[74] = pow(input_x[0], 1) * pow(input_x[1], 2) * pow(input_x[2], 3);
      idvg_poly_feat[75] = pow(input_x[0], 1) * pow(input_x[1], 1) * pow(input_x[2], 4);
      idvg_poly_feat[76] = pow(input_x[0], 1) * pow(input_x[2], 5);
      idvg_poly_feat[77] = pow(input_x[1], 6);
      idvg_poly_feat[78] = pow(input_x[1], 5) * pow(input_x[2], 1);
      idvg_poly_feat[79] = pow(input_x[1], 4) * pow(input_x[2], 2);
      idvg_poly_feat[80] = pow(input_x[1], 3) * pow(input_x[2], 3);
      idvg_poly_feat[81] = pow(input_x[1], 2) * pow(input_x[2], 4);
      idvg_poly_feat[82] = pow(input_x[1], 1) * pow(input_x[2], 5);
      idvg_poly_feat[83] = pow(input_x[2], 6);
      idvg_poly_feat[84] = pow(input_x[0], 7);
      idvg_poly_feat[85] = pow(input_x[0], 6) * pow(input_x[1], 1);
      idvg_poly_feat[86] = pow(input_x[0], 6) * pow(input_x[2], 1);
      idvg_poly_feat[87] = pow(input_x[0], 5) * pow(input_x[1], 2);
      idvg_poly_feat[88] = pow(input_x[0], 5) * pow(input_x[1], 1) * pow(input_x[2], 1);
      idvg_poly_feat[89] = pow(input_x[0], 5) * pow(input_x[2], 2);
      idvg_poly_feat[90] = pow(input_x[0], 4) * pow(input_x[1], 3);
      idvg_poly_feat[91] = pow(input_x[0], 4) * pow(input_x[1], 2) * pow(input_x[2], 1);
      idvg_poly_feat[92] = pow(input_x[0], 4) * pow(input_x[1], 1) * pow(input_x[2], 2);
      idvg_poly_feat[93] = pow(input_x[0], 4) * pow(input_x[2], 3);
      idvg_poly_feat[94] = pow(input_x[0], 3) * pow(input_x[1], 4);
      idvg_poly_feat[95] = pow(input_x[0], 3) * pow(input_x[1], 3) * pow(input_x[2], 1);
      idvg_poly_feat[96] = pow(input_x[0], 3) * pow(input_x[1], 2) * pow(input_x[2], 2);
      idvg_poly_feat[97] = pow(input_x[0], 3) * pow(input_x[1], 1) * pow(input_x[2], 3);
      idvg_poly_feat[98] = pow(input_x[0], 3) * pow(input_x[2], 4);
      idvg_poly_feat[99] = pow(input_x[0], 2) * pow(input_x[1], 5);
      idvg_poly_feat[100] = pow(input_x[0], 2) * pow(input_x[1], 4) * pow(input_x[2], 1);
      idvg_poly_feat[101] = pow(input_x[0], 2) * pow(input_x[1], 3) * pow(input_x[2], 2);
      idvg_poly_feat[102] = pow(input_x[0], 2) * pow(input_x[1], 2) * pow(input_x[2], 3);
      idvg_poly_feat[103] = pow(input_x[0], 2) * pow(input_x[1], 1) * pow(input_x[2], 4);
      idvg_poly_feat[104] = pow(input_x[0], 2) * pow(input_x[2], 5);
      idvg_poly_feat[105] = pow(input_x[0], 1) * pow(input_x[1], 6);
      idvg_poly_feat[106] = pow(input_x[0], 1) * pow(input_x[1], 5) * pow(input_x[2], 1);
      idvg_poly_feat[107] = pow(input_x[0], 1) * pow(input_x[1], 4) * pow(input_x[2], 2);
      idvg_poly_feat[108] = pow(input_x[0], 1) * pow(input_x[1], 3) * pow(input_x[2], 3);
      idvg_poly_feat[109] = pow(input_x[0], 1) * pow(input_x[1], 2) * pow(input_x[2], 4);
      idvg_poly_feat[110] = pow(input_x[0], 1) * pow(input_x[1], 1) * pow(input_x[2], 5);
      idvg_poly_feat[111] = pow(input_x[0], 1) * pow(input_x[2], 6);
      idvg_poly_feat[112] = pow(input_x[1], 7);
      idvg_poly_feat[113] = pow(input_x[1], 6) * pow(input_x[2], 1);
      idvg_poly_feat[114] = pow(input_x[1], 5) * pow(input_x[2], 2);
      idvg_poly_feat[115] = pow(input_x[1], 4) * pow(input_x[2], 3);
      idvg_poly_feat[116] = pow(input_x[1], 3) * pow(input_x[2], 4);
      idvg_poly_feat[117] = pow(input_x[1], 2) * pow(input_x[2], 5);
      idvg_poly_feat[118] = pow(input_x[1], 1) * pow(input_x[2], 6);
      idvg_poly_feat[119] = pow(input_x[2], 7);
      for(i=0; i<5; i=i+1) begin
        tmp = idvg_poly_b[i];
        for(j=0; j<120; j=j+1) tmp = tmp + idvg_poly_w[i*120 + j] * idvg_poly_feat[j];
        idvg_z[i] = tmp * idvg_sl_mul[i] + idvg_sl_add[i];
      end
      for(i=0; i<50; i=i+1) begin
        tmp = idvg_ae_b0[i];
        for(j=0; j<5; j=j+1) tmp = tmp + idvg_ae_w0[i*5 + j] * idvg_z[j];
        idvg_h0[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<200; i=i+1) begin
        tmp = idvg_ae_b1[i];
        for(j=0; j<50; j=j+1) tmp = tmp + idvg_ae_w1[i*50 + j] * idvg_h0[j];
        idvg_h1[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<400; i=i+1) begin
        tmp = idvg_ae_b2[i];
        for(j=0; j<200; j=j+1) tmp = tmp + idvg_ae_w2[i*200 + j] * idvg_h1[j];
        idvg_h2[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<400; i=i+1) begin
        tmp = idvg_ae_b3[i];
        for(j=0; j<400; j=j+1) tmp = tmp + idvg_ae_w3[i*400 + j] * idvg_h2[j];
        tmp = 1.0 / (1.0 + exp(-tmp));
        idvg_out[i] = tmp * idvg_siv_mul[i] + idvg_siv_add[i];
      end
    end

    val_vg = V(g, s);
    val_vd = V(d, s);
    sign_vd = val_vd / sqrt(val_vd*val_vd + vds_sign_delta*vds_sign_delta);
    vd_mag = sqrt(val_vd*val_vd + vds_sign_delta*vds_sign_delta);

    // Id-Vd surface: 4 Vg anchors x 200 Vd samples
    if(val_vg <= 0.25) begin
      idvd_vg0_idx = 0;
      idvd_vg1_idx = 1;
      idvd_vg_frac = 0.0;
      idvd_excess = 0.25 - val_vg;
    end else if(val_vg >= 1.0) begin
      idvd_vg0_idx = 2;
      idvd_vg1_idx = 3;
      idvd_vg_frac = 1.0;
      idvd_excess = val_vg - 1.0;
    end else begin
      idvd_vg_pos = (val_vg - 0.25) / 0.25;
      idvd_vg0_idx = $rtoi(idvd_vg_pos);
      if(idvd_vg0_idx > 2) idvd_vg0_idx = 2;
      idvd_vg1_idx = idvd_vg0_idx + 1;
      idvd_vg_frac = idvd_vg_pos - idvd_vg0_idx;
      idvd_excess = 0.0;
    end

    if(vd_mag <= 0.0025) begin
      idvd_vd0_idx = 0;
      idvd_vd1_idx = 1;
      idvd_vd_frac = 0.0;
    end else if(vd_mag >= 1.0) begin
      idvd_vd0_idx = 198;
      idvd_vd1_idx = 199;
      idvd_vd_frac = 1.0;
    end else begin
      idvd_vd_pos = (vd_mag - 0.0025) / (0.9975 / 199.0);
      idvd_vd0_idx = $rtoi(idvd_vd_pos);
      if(idvd_vd0_idx > 198) idvd_vd0_idx = 198;
      idvd_vd1_idx = idvd_vd0_idx + 1;
      idvd_vd_frac = idvd_vd_pos - idvd_vd0_idx;
    end

    idvd_i00 = idvd_out[idvd_vg0_idx * 200 + idvd_vd0_idx];
    idvd_i01 = idvd_out[idvd_vg0_idx * 200 + idvd_vd1_idx];
    idvd_i10 = idvd_out[idvd_vg1_idx * 200 + idvd_vd0_idx];
    idvd_i11 = idvd_out[idvd_vg1_idx * 200 + idvd_vd1_idx];
    idvd_interp = (1.0 - idvd_vg_frac) * ((1.0 - idvd_vd_frac) * idvd_i00 + idvd_vd_frac * idvd_i01)
                + idvd_vg_frac * ((1.0 - idvd_vd_frac) * idvd_i10 + idvd_vd_frac * idvd_i11);
    if(idvd_interp < 0.0) idvd_interp = 0.0;

    // Id-Vg surface: 2 Vd anchors x 200 Vg samples
    if(val_vg <= 0.0025) begin
      idvg_vg0_idx = 0;
      idvg_vg1_idx = 1;
      idvg_vg_frac = 0.0;
    end else if(val_vg >= 1.0) begin
      idvg_vg0_idx = 198;
      idvg_vg1_idx = 199;
      idvg_vg_frac = 1.0;
    end else begin
      idvg_vg_pos = (val_vg - 0.0025) / (0.9975 / 199.0);
      idvg_vg0_idx = $rtoi(idvg_vg_pos);
      if(idvg_vg0_idx > 198) idvg_vg0_idx = 198;
      idvg_vg1_idx = idvg_vg0_idx + 1;
      idvg_vg_frac = idvg_vg_pos - idvg_vg0_idx;
    end

    if(vd_mag <= 0.05) begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = 0.0;
      idvg_excess = 0.05 - vd_mag;
    end else if(vd_mag >= 1.0) begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = 1.0;
      idvg_excess = vd_mag - 1.0;
    end else begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = (vd_mag - 0.05) / 0.95;
      idvg_excess = 0.0;
    end

    idvg_i00 = idvg_out[idvg_vd0_idx * 200 + idvg_vg0_idx];
    idvg_i01 = idvg_out[idvg_vd0_idx * 200 + idvg_vg1_idx];
    idvg_i10 = idvg_out[idvg_vd1_idx * 200 + idvg_vg0_idx];
    idvg_i11 = idvg_out[idvg_vd1_idx * 200 + idvg_vg1_idx];
    idvg_interp = (1.0 - idvg_vd_frac) * ((1.0 - idvg_vg_frac) * idvg_i00 + idvg_vg_frac * idvg_i01)
                + idvg_vd_frac * ((1.0 - idvg_vg_frac) * idvg_i10 + idvg_vg_frac * idvg_i11);
    if(idvg_interp < 0.0) idvg_interp = 0.0;

    if(idvd_vg_frac < 0.5) idvd_vg_dist = 2.0 * idvd_vg_frac;
    else idvd_vg_dist = 2.0 * (1.0 - idvd_vg_frac);
    if(idvg_vd_frac < 0.5) idvg_vd_dist = 2.0 * idvg_vd_frac;
    else idvg_vd_dist = 2.0 * (1.0 - idvg_vd_frac);

    w_idvd = 1.0 / (0.05 + (idvd_vg_dist + 2.0 * idvd_excess) * (idvd_vg_dist + 2.0 * idvd_excess));
    w_idvg = 1.0 / (0.05 + (idvg_vd_dist + 2.0 * idvg_excess) * (idvg_vd_dist + 2.0 * idvg_excess));

    if(current_mode == 1) begin
      res_id_mag = idvd_interp;
    end else if(current_mode == 2) begin
      res_id_mag = idvg_interp;
    end else begin
      w_sum = w_idvd + w_idvg;
      if(w_sum > 0.0) res_id_mag = (w_idvd * idvd_interp + w_idvg * idvg_interp) / w_sum;
      else res_id_mag = 0.5 * (idvd_interp + idvg_interp);
    end

    if(res_id_mag < 0.0) res_id_mag = 0.0;
    I(d, s) <+ sign_vd * res_id_mag;
    I(d, s) <+ gmin_ds * V(d, s);
  end
endmodule