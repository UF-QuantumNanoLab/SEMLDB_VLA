      for(i=0; i<400; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_b2[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_w3.txt", "r");
      for(i=0; i<160000; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_w3[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvg_ae_b3.txt", "r");
      for(i=0; i<400; i=i+1) count_tmp = $fscanf(fd, "%e", idvg_ae_b3[i]);
      $fclose(fd);
      fd = $fopen("/home/UFAD/tanvir.ahmed/Desktop/Verilog/NMOS/out/nfet_idvd_sx_mul.txt", "r");
      for(i=0; i<3; i=i+1) count_tmp = $fscanf(fd, "%e", idvd_sx_mul[i]);
