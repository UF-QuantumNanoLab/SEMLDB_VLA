      idvd_poly_feat[91] = pow(input_x[0], 4) * pow(input_x[1], 2) * pow(input_x[2], 1);
      idvd_poly_feat[92] = pow(input_x[0], 4) * pow(input_x[1], 1) * pow(input_x[2], 2);
