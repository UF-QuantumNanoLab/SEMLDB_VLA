      idvg_poly_feat[742] = pow(input_x[3], 3) * pow(input_x[4], 1) * pow(input_x[6], 1);
      idvg_poly_feat[743] = pow(input_x[3], 3) * pow(input_x[5], 2);
      idvg_poly_feat[744] = pow(input_x[3], 3) * pow(input_x[5], 1) * pow(input_x[6], 1);
      idvg_poly_feat[745] = pow(input_x[3], 3) * pow(input_x[6], 2);
      idvg_poly_feat[746] = pow(input_x[3], 2) * pow(input_x[4], 3);
      idvg_poly_feat[747] = pow(input_x[3], 2) * pow(input_x[4], 2) * pow(input_x[5], 1);
      idvg_poly_feat[748] = pow(input_x[3], 2) * pow(input_x[4], 2) * pow(input_x[6], 1);
      idvg_poly_feat[749] = pow(input_x[3], 2) * pow(input_x[4], 1) * pow(input_x[5], 2);
      idvg_poly_feat[750] = pow(input_x[3], 2) * pow(input_x[4], 1) * pow(input_x[5], 1) * pow(input_x[6], 1);
      idvg_poly_feat[751] = pow(input_x[3], 2) * pow(input_x[4], 1) * pow(input_x[6], 2);
      idvg_poly_feat[752] = pow(input_x[3], 2) * pow(input_x[5], 3);
      idvg_poly_feat[753] = pow(input_x[3], 2) * pow(input_x[5], 2) * pow(input_x[6], 1);
      idvg_poly_feat[754] = pow(input_x[3], 2) * pow(input_x[5], 1) * pow(input_x[6], 2);
      idvg_poly_feat[755] = pow(input_x[3], 2) * pow(input_x[6], 3);
      idvg_poly_feat[756] = pow(input_x[3], 1) * pow(input_x[4], 4);
      idvg_poly_feat[757] = pow(input_x[3], 1) * pow(input_x[4], 3) * pow(input_x[5], 1);
      idvg_poly_feat[758] = pow(input_x[3], 1) * pow(input_x[4], 3) * pow(input_x[6], 1);
      idvg_poly_feat[759] = pow(input_x[3], 1) * pow(input_x[4], 2) * pow(input_x[5], 2);
      idvg_poly_feat[760] = pow(input_x[3], 1) * pow(input_x[4], 2) * pow(input_x[5], 1) * pow(input_x[6], 1);
      idvg_poly_feat[761] = pow(input_x[3], 1) * pow(input_x[4], 2) * pow(input_x[6], 2);
      idvg_poly_feat[762] = pow(input_x[3], 1) * pow(input_x[4], 1) * pow(input_x[5], 3);
      idvg_poly_feat[763] = pow(input_x[3], 1) * pow(input_x[4], 1) * pow(input_x[5], 2) * pow(input_x[6], 1);
      idvg_poly_feat[764] = pow(input_x[3], 1) * pow(input_x[4], 1) * pow(input_x[5], 1) * pow(input_x[6], 2);
      idvg_poly_feat[765] = pow(input_x[3], 1) * pow(input_x[4], 1) * pow(input_x[6], 3);
      idvg_poly_feat[766] = pow(input_x[3], 1) * pow(input_x[5], 4);
      idvg_poly_feat[767] = pow(input_x[3], 1) * pow(input_x[5], 3) * pow(input_x[6], 1);
      idvg_poly_feat[768] = pow(input_x[3], 1) * pow(input_x[5], 2) * pow(input_x[6], 2);
      idvg_poly_feat[769] = pow(input_x[3], 1) * pow(input_x[5], 1) * pow(input_x[6], 3);
      idvg_poly_feat[770] = pow(input_x[3], 1) * pow(input_x[6], 4);
      idvg_poly_feat[771] = pow(input_x[4], 5);
      idvg_poly_feat[772] = pow(input_x[4], 4) * pow(input_x[5], 1);
      idvg_poly_feat[773] = pow(input_x[4], 4) * pow(input_x[6], 1);
      idvg_poly_feat[774] = pow(input_x[4], 3) * pow(input_x[5], 2);
      idvg_poly_feat[775] = pow(input_x[4], 3) * pow(input_x[5], 1) * pow(input_x[6], 1);
      idvg_poly_feat[776] = pow(input_x[4], 3) * pow(input_x[6], 2);
      idvg_poly_feat[777] = pow(input_x[4], 2) * pow(input_x[5], 3);
      idvg_poly_feat[778] = pow(input_x[4], 2) * pow(input_x[5], 2) * pow(input_x[6], 1);
      idvg_poly_feat[779] = pow(input_x[4], 2) * pow(input_x[5], 1) * pow(input_x[6], 2);
      idvg_poly_feat[780] = pow(input_x[4], 2) * pow(input_x[6], 3);
      idvg_poly_feat[781] = pow(input_x[4], 1) * pow(input_x[5], 4);
      idvg_poly_feat[782] = pow(input_x[4], 1) * pow(input_x[5], 3) * pow(input_x[6], 1);
      idvg_poly_feat[783] = pow(input_x[4], 1) * pow(input_x[5], 2) * pow(input_x[6], 2);
      idvg_poly_feat[784] = pow(input_x[4], 1) * pow(input_x[5], 1) * pow(input_x[6], 3);
      idvg_poly_feat[785] = pow(input_x[4], 1) * pow(input_x[6], 4);
      idvg_poly_feat[786] = pow(input_x[5], 5);
      idvg_poly_feat[787] = pow(input_x[5], 4) * pow(input_x[6], 1);
      idvg_poly_feat[788] = pow(input_x[5], 3) * pow(input_x[6], 2);
      idvg_poly_feat[789] = pow(input_x[5], 2) * pow(input_x[6], 3);
      idvg_poly_feat[790] = pow(input_x[5], 1) * pow(input_x[6], 4);
      idvg_poly_feat[791] = pow(input_x[6], 5);
      idvg_poly_feat[792] = pow(input_x[0], 6);
      idvg_poly_feat[793] = pow(input_x[1], 6);
      idvg_poly_feat[794] = pow(input_x[2], 6);
      idvg_poly_feat[795] = pow(input_x[3], 6);
      idvg_poly_feat[796] = pow(input_x[4], 6);
      idvg_poly_feat[797] = pow(input_x[5], 6);
      idvg_poly_feat[798] = pow(input_x[6], 6);
      idvg_poly_feat[799] = pow(input_x[0], 7);
      idvg_poly_feat[800] = pow(input_x[1], 7);
      idvg_poly_feat[801] = pow(input_x[2], 7);
      idvg_poly_feat[802] = pow(input_x[3], 7);
      idvg_poly_feat[803] = pow(input_x[4], 7);
      idvg_poly_feat[804] = pow(input_x[5], 7);
      idvg_poly_feat[805] = pow(input_x[6], 7);
      idvg_poly_feat[806] = pow(input_x[0], 8);
      idvg_poly_feat[807] = pow(input_x[1], 8);
      idvg_poly_feat[808] = pow(input_x[2], 8);
      idvg_poly_feat[809] = pow(input_x[3], 8);
      idvg_poly_feat[810] = pow(input_x[4], 8);
      idvg_poly_feat[811] = pow(input_x[5], 8);
      idvg_poly_feat[812] = pow(input_x[6], 8);
      idvg_poly_feat[813] = pow(input_x[0], 9);
      idvg_poly_feat[814] = pow(input_x[1], 9);
      idvg_poly_feat[815] = pow(input_x[2], 9);
      idvg_poly_feat[816] = pow(input_x[3], 9);
      idvg_poly_feat[817] = pow(input_x[4], 9);
      idvg_poly_feat[818] = pow(input_x[5], 9);
      idvg_poly_feat[819] = pow(input_x[6], 9);
      idvg_poly_feat[820] = pow(input_x[0], 10);
      idvg_poly_feat[821] = pow(input_x[1], 10);
      idvg_poly_feat[822] = pow(input_x[2], 10);
      idvg_poly_feat[823] = pow(input_x[3], 10);
      idvg_poly_feat[824] = pow(input_x[4], 10);
      idvg_poly_feat[825] = pow(input_x[5], 10);
      idvg_poly_feat[826] = pow(input_x[6], 10);
      idvg_poly_feat[827] = pow(input_x[0], 11);
      idvg_poly_feat[828] = pow(input_x[1], 11);
      idvg_poly_feat[829] = pow(input_x[2], 11);
      idvg_poly_feat[830] = pow(input_x[3], 11);
      idvg_poly_feat[831] = pow(input_x[4], 11);
      idvg_poly_feat[832] = pow(input_x[5], 11);
      idvg_poly_feat[833] = pow(input_x[6], 11);
      idvg_poly_feat[834] = pow(input_x[0], 12);
      idvg_poly_feat[835] = pow(input_x[1], 12);
      idvg_poly_feat[836] = pow(input_x[2], 12);
      idvg_poly_feat[837] = pow(input_x[3], 12);
      idvg_poly_feat[838] = pow(input_x[4], 12);
      idvg_poly_feat[839] = pow(input_x[5], 12);
      idvg_poly_feat[840] = pow(input_x[6], 12);
      for(i=0; i<20; i=i+1) begin
        tmp = idvg_poly_b[i];
        for(j=0; j<841; j=j+1) tmp = tmp + idvg_poly_w[i*841 + j] * idvg_poly_feat[j];
        idvg_z[i] = tmp * idvg_sl_mul[i] + idvg_sl_add[i];
      end
      for(i=0; i<112; i=i+1) begin
        tmp = idvg_ae_b0[i];
        for(j=0; j<20; j=j+1) tmp = tmp + idvg_ae_w0[i*20 + j] * idvg_z[j];
        idvg_h0[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<446; i=i+1) begin
        tmp = idvg_ae_b1[i];
        for(j=0; j<112; j=j+1) tmp = tmp + idvg_ae_w1[i*112 + j] * idvg_h0[j];
        idvg_h1[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<892; i=i+1) begin
        tmp = idvg_ae_b2[i];
        for(j=0; j<446; j=j+1) tmp = tmp + idvg_ae_w2[i*446 + j] * idvg_h1[j];
        idvg_h2[i] = (tmp > 0.0) ? tmp : 0.0;
      end
      for(i=0; i<892; i=i+1) begin
        tmp = idvg_ae_b3[i];
        for(j=0; j<892; j=j+1) tmp = tmp + idvg_ae_w3[i*892 + j] * idvg_h2[j];
        tmp = 1.0 / (1.0 + exp(-tmp));
        idvg_out[i] = tmp * idvg_siv_mul[i] + idvg_siv_add[i];
      end
    end

    val_vg = V(g, s);
    val_vd = V(d, s);
    sign_vd = val_vd / sqrt(val_vd*val_vd + vds_sign_delta*vds_sign_delta);
    vd_mag = sqrt(val_vd*val_vd + vds_sign_delta*vds_sign_delta);

    // Id-Vd surface: 3 Vg anchors x 300 Vd samples
    if(val_vg <= 1.0) begin
      idvd_vg0_idx = 0;
      idvd_vg1_idx = 1;
      idvd_vg_frac = 0.0;
      idvd_excess = 1.0 - val_vg;
    end else if(val_vg >= 5.0) begin
      idvd_vg0_idx = 1;
      idvd_vg1_idx = 2;
      idvd_vg_frac = 1.0;
      idvd_excess = val_vg - 5.0;
    end else begin
      idvd_vg_pos = (val_vg - 1.0) / 2.0;
      idvd_vg0_idx = $rtoi(idvd_vg_pos);
      if(idvd_vg0_idx > 1) idvd_vg0_idx = 1;
      idvd_vg1_idx = idvd_vg0_idx + 1;
      idvd_vg_frac = idvd_vg_pos - idvd_vg0_idx;
      idvd_excess = 0.0;
    end

    if(vd_mag <= 0.02) begin
      idvd_vd0_idx = 0;
      idvd_vd1_idx = 1;
      idvd_vd_frac = 0.0;
    end else if(vd_mag >= 18.0) begin
      idvd_vd0_idx = 298;
      idvd_vd1_idx = 299;
      idvd_vd_frac = 1.0;
    end else begin
      idvd_vd_pos = (vd_mag - 0.02) / (17.98 / 299.0);
      idvd_vd0_idx = $rtoi(idvd_vd_pos);
      if(idvd_vd0_idx > 298) idvd_vd0_idx = 298;
      idvd_vd1_idx = idvd_vd0_idx + 1;
      idvd_vd_frac = idvd_vd_pos - idvd_vd0_idx;
    end

    idvd_i00 = idvd_out[idvd_vg0_idx * 300 + idvd_vd0_idx];
    idvd_i01 = idvd_out[idvd_vg0_idx * 300 + idvd_vd1_idx];
    idvd_i10 = idvd_out[idvd_vg1_idx * 300 + idvd_vd0_idx];
    idvd_i11 = idvd_out[idvd_vg1_idx * 300 + idvd_vd1_idx];
    idvd_interp = (1.0 - idvd_vg_frac) * ((1.0 - idvd_vd_frac) * idvd_i00 + idvd_vd_frac * idvd_i01)
                + idvd_vg_frac * ((1.0 - idvd_vd_frac) * idvd_i10 + idvd_vd_frac * idvd_i11);

    // Id-Vg surface: 2 Vd anchors x 446 Vg samples
    if(val_vg <= -1.9) begin
      idvg_vg0_idx = 0;
      idvg_vg1_idx = 1;
      idvg_vg_frac = 0.0;
    end else if(val_vg >= 7.0) begin
      idvg_vg0_idx = 444;
      idvg_vg1_idx = 445;
      idvg_vg_frac = 1.0;
    end else begin
      idvg_vg_pos = (val_vg + 1.9) / 0.02;
      idvg_vg0_idx = $rtoi(idvg_vg_pos);
      if(idvg_vg0_idx > 444) idvg_vg0_idx = 444;
      idvg_vg1_idx = idvg_vg0_idx + 1;
      idvg_vg_frac = idvg_vg_pos - idvg_vg0_idx;
    end

    if(vd_mag <= 1.0) begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = 0.0;
      idvg_excess = 1.0 - vd_mag;
    end else if(vd_mag >= 15.0) begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = 1.0;
      idvg_excess = vd_mag - 15.0;
    end else begin
      idvg_vd0_idx = 0;
      idvg_vd1_idx = 1;
      idvg_vd_frac = (vd_mag - 1.0) / 14.0;
      idvg_excess = 0.0;
    end

    idvg_i00 = idvg_out[idvg_vd0_idx * 446 + idvg_vg0_idx];
    idvg_i01 = idvg_out[idvg_vd0_idx * 446 + idvg_vg1_idx];
    idvg_i10 = idvg_out[idvg_vd1_idx * 446 + idvg_vg0_idx];
    idvg_i11 = idvg_out[idvg_vd1_idx * 446 + idvg_vg1_idx];
    idvg_interp = (1.0 - idvg_vd_frac) * ((1.0 - idvg_vg_frac) * idvg_i00 + idvg_vg_frac * idvg_i01)
                + idvg_vd_frac * ((1.0 - idvg_vg_frac) * idvg_i10 + idvg_vg_frac * idvg_i11);

    if(idvd_vg_frac < 0.5) idvd_vg_dist = 2.0 * idvd_vg_frac;
    else idvd_vg_dist = 2.0 * (1.0 - idvd_vg_frac);
    if(idvg_vd_frac < 0.5) idvg_vd_dist = 2.0 * idvg_vd_frac;
    else idvg_vd_dist = 2.0 * (1.0 - idvg_vd_frac);

    w_idvd = 1.0 / (0.05 + (idvd_vg_dist + 2.0 * idvd_excess) * (idvd_vg_dist + 2.0 * idvd_excess));
    w_idvg = 1.0 / (0.05 + (idvg_vd_dist + 2.0 * idvg_excess) * (idvg_vd_dist + 2.0 * idvg_excess));

    if(current_mode == 1) begin
      res_id_mag = idvd_interp;
    end else if(current_mode == 2) begin
      res_id_mag = idvg_interp;
    end else begin
      w_sum = w_idvd + w_idvg;
      if(w_sum > 0.0) res_id_mag = (w_idvd * idvd_interp + w_idvg * idvg_interp) / w_sum;
      else res_id_mag = 0.5 * (idvd_interp + idvg_interp);
    end

    I(d, s) <+ sign_vd * res_id_mag;
    I(d, s) <+ gmin_ds * V(d, s);
  end
endmodule